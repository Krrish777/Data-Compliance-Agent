# ── Required ────────────────────────────────────────────────────────
# Groq LLM API key — get one free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# ── Optional: LangSmith tracing (already wired in the codebase) ─────
LANGSMITH_API_KEY=lsv2_pt_your_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=data-compliance-agent

# ── Optional: Redis cache (falls back to in-memory LRU if unset) ────
# REDIS_URL=redis://localhost:6379/0
