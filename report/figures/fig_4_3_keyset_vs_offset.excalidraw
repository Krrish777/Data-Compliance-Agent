    {"type":"text","id":"caption_text","x":200,"y":800,"width":1020,"height":60,"text":"Measured on the bundled IBM HI-Small AML transactions table (~200k rows). Keyset pagination is implemented in\nsrc/agents/tools/database/query_builder.py:14-58 with the cursor predicate AND \"<pk>\" > :last_pk.\nThe OFFSET variant was timed as a one-off experiment, not shipped.","originalText":"Measured on the bundled IBM HI-Small AML transactions table (~200k rows). Keyset pagination is implemented in\nsrc/agents/tools/database/query_builder.py:14-58 with the cursor predicate AND \"<pk>\" > :last_pk.\nThe OFFSET variant was timed as a one-off experiment, not shipped.","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#374151","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":434003,"version":1,"versionNonce":434004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"caption_box","lineHeight":1.25}
