    {"type":"text","id":"re_cols","x":100,"y":214,"width":410,"height":330,"text":"PK   id                  INTEGER\nUK   scan_id             TEXT  NOT NULL\nUK   rule_id             TEXT  NOT NULL\n     violation_count     INTEGER  DEFAULT 0\n     severity            TEXT  DEFAULT 'MEDIUM'\n     explanation         TEXT\n     policy_clause       TEXT\n     remediation_steps   TEXT  (JSON)\n     risk_description    TEXT\n     generated_at        TEXT  NOT NULL\n\nUNIQUE (scan_id, rule_id)","originalText":"PK   id                  INTEGER\nUK   scan_id             TEXT  NOT NULL\nUK   rule_id             TEXT  NOT NULL\n     violation_count     INTEGER  DEFAULT 0\n     severity            TEXT  DEFAULT 'MEDIUM'\n     explanation         TEXT\n     policy_clause       TEXT\n     remediation_steps   TEXT  (JSON)\n     risk_description    TEXT\n     generated_at        TEXT  NOT NULL\n\nUNIQUE (scan_id, rule_id)","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1f2937","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":210007,"version":1,"versionNonce":210008,"isDeleted":false,"groupIds":["re_entity"],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

