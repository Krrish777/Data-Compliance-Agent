    {"type":"text","id":"idx_body","x":1360,"y":196,"width":320,"height":240,"text":"• idx_violations_scan_id\n• idx_violations_rule_id\n• idx_violations_table\n• idx_violations_confidence\n• idx_violations_status\n• idx_violations_detected_at\n\nSpeed up the 4 canonical\nretrieval paths used by the\nreporting node + HITL surfaces.","originalText":"• idx_violations_scan_id\n• idx_violations_rule_id\n• idx_violations_table\n• idx_violations_confidence\n• idx_violations_status\n• idx_violations_detected_at\n\nSpeed up the 4 canonical\nretrieval paths used by the\nreporting node + HITL surfaces.","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1f2937","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":240005,"version":1,"versionNonce":240006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

