    {"type":"text","id":"virt_body","x":1360,"y":528,"width":320,"height":200,"text":"Scan\n  scan_id = state['scan_id']\n  started_at, config, mode\n\nRule\n  rule_id = structured_rule.id\n  rule_text, target_column,\n  operator, value, complexity\n\n→ Only rule_id / scan_id\n   footprints are persisted.","originalText":"Scan\n  scan_id = state['scan_id']\n  started_at, config, mode\n\nRule\n  rule_id = structured_rule.id\n  rule_text, target_column,\n  operator, value, complexity\n\n→ Only rule_id / scan_id\n   footprints are persisted.","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1f2937","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":250005,"version":1,"versionNonce":250006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"text","id":"legend","x":80,"y":790,"width":1200,"height":22,"text":"Legend:   PK = primary key     UK = part of UNIQUE constraint     IX = indexed column     FK* = logical foreign key (no DDL constraint; joined on composite scan_id+rule_id)","originalText":"Legend:   PK = primary key     UK = part of UNIQUE constraint     IX = indexed column     FK* = logical foreign key (no DDL constraint; joined on composite scan_id+rule_id)","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":260001,"version":1,"versionNonce":260002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
