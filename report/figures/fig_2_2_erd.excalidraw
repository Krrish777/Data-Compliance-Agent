    {"type":"text","id":"vl_cols","x":840,"y":214,"width":430,"height":510,"text":"PK    id                   INTEGER\nFK*   scan_id              TEXT  NOT NULL\n      scan_timestamp       TEXT  NOT NULL\nFK*   rule_id              TEXT  NOT NULL\n      rule_text            TEXT\n      rule_source          TEXT\nIX    table_name           TEXT  NOT NULL\n      record_primary_key   TEXT  NOT NULL\n      violating_data       TEXT  (JSON)\nIX    confidence           REAL  NOT NULL\n      violation_type       TEXT\nIX    detected_at          TEXT  NOT NULL  DEFAULT now\nIX    review_status        TEXT  DEFAULT 'pending'\n      reviewed_by          TEXT\n      reviewed_at          TEXT\n      reviewer_notes       TEXT\n\nFK*  logical only — joins on (scan_id, rule_id)","originalText":"PK    id                   INTEGER\nFK*   scan_id              TEXT  NOT NULL\n      scan_timestamp       TEXT  NOT NULL\nFK*   rule_id              TEXT  NOT NULL\n      rule_text            TEXT\n      rule_source          TEXT\nIX    table_name           TEXT  NOT NULL\n      record_primary_key   TEXT  NOT NULL\n      violating_data       TEXT  (JSON)\nIX    confidence           REAL  NOT NULL\n      violation_type       TEXT\nIX    detected_at          TEXT  NOT NULL  DEFAULT now\nIX    review_status        TEXT  DEFAULT 'pending'\n      reviewed_by          TEXT\n      reviewed_at          TEXT\n      reviewer_notes       TEXT\n\nFK*  logical only — joins on (scan_id, rule_id)","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1f2937","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":220007,"version":1,"versionNonce":220008,"isDeleted":false,"groupIds":["vl_entity"],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

